# ─────────────────────────────────────────────────────────────────────────────
#  Vision Motors — environment variables
#  Copy to .env.local for local development. NEVER commit real values.
# ─────────────────────────────────────────────────────────────────────────────

# GoHighLevel inbound webhook that receives booking enquiries.
# In GHL: Workflow → trigger "Inbound Webhook" → copy the URL here.
# The workflow should (a) email the enquiry to Vision Motors and (b) create the contact.
#
# SERVER-ONLY (no NEXT_PUBLIC_ prefix) — this value never reaches the browser bundle.
# While unset, the booking form runs in DEMO MODE: it validates and shows the success
# state, but forwards nothing. See app/api/booking/route.ts.
GHL_WEBHOOK_URL=
